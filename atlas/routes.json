    { "route": "camerareel",       "path": "/client?panel=explore&tab=reel",       "auth": "auth", "source": "catalyst-camera-reel" },
    { "route": "credits",          "path": "/client?panel=explore&tab=credits",    "auth": "auth", "source": "catalyst-credits" },
    { "route": "profilewidget",    "path": "/client",                              "auth": "auth", "source": "GetParams identity (GATED worker-gap; static seed otherwise)" },
    { "route": "connectionstatus", "path": "/client",                              "auth": "anon", "source": "live realm connectivity (static when no engine)" },
    { "route": "minimap",          "path": "/client",                              "auth": "anon", "source": "LiveSceneInfo via /live_scenes (title only; coords/realm lost through console string)" }
  ]
}

#!/usr/bin/env bash
# dcl-log-monitor — watch the Unity editor console log and push it to a Claude Code
# instance running in a tmux pane.
#
#   ERROR / Exception / "error CS"  -> delivered IMMEDIATELY (one message each)
#   Warning / Debug / Info          -> buffered, flushed as ONE digest every N seconds
#
# Delivery = `tmux send-keys` into the pane running `claude`, so the live instance
# receives each as a normal message. If the tmux session is absent, lines are spooled
# to $SPOOL/undelivered.log so nothing is lost.
#
#   dcl-log-monitor [--log <file>] [--tmux <session>] [--digest <secs>]
#   env: DCL_MONITOR_LOG  DCL_MONITOR_TMUX(=claude)  DCL_MONITOR_DIGEST(=60)  DCL_MONITOR_SPOOL
#
# Portable bash (Linux dcl-editor + macOS host). Stop with Ctrl-C.
set -uo pipefail
SESSION="${DCL_MONITOR_TMUX:-claude}"
DIGEST="${DCL_MONITOR_DIGEST:-60}"
SPOOL="${DCL_MONITOR_SPOOL:-/tmp/dcl-monitor}"
LOG="${DCL_MONITOR_LOG:-}"
while [ $# -gt 0 ]; do case "$1" in
  --log)    LOG="$2"; shift 2;;
  --tmux)   SESSION="$2"; shift 2;;
  --digest) DIGEST="$2"; shift 2;;
  -h|--help) sed -n '2,16p' "$0"; exit 0;;
  *) echo "dcl-log-monitor: unknown arg: $1" >&2; exit 64;;
esac; done

# Default log: the rig's DCL_MAC_LOG from config.sh (else pass --log).
if [ -z "$LOG" ]; then
  _HERE="$(cd "$(dirname "$0")" && pwd)"
  [ -f "$_HERE/config.sh" ] && LOG="$(bash -c ". '$_HERE/config.sh' >/dev/null 2>&1; printf '%s' \"\${DCL_MAC_LOG:-}\"" 2>/dev/null)"
fi
[ -n "$LOG" ] || { echo "dcl-log-monitor: no --log and no resolvable default" >&2; exit 2; }
command -v tmux >/dev/null || { echo "dcl-log-monitor: tmux not found" >&2; exit 2; }
mkdir -p "$SPOOL"
DBUF="$SPOOL/digest.buf"; : > "$DBUF"

deliver() {  # $1 = single-line message
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux send-keys -t "$SESSION" -l -- "$1"
    tmux send-keys -t "$SESSION" Enter
  else
    printf '%s\n' "$1" >> "$SPOOL/undelivered.log"
  fi
}

classify() {  # ERROR | WARN | INFO  (case-insensitive)
  local l; l=$(printf '%s' "$1" | tr 'A-Z' 'a-z')
  case "$l" in
    *"error cs"*|*exception*|*nullreference*|*"[error]"*|*"aborting batchmode"*|*"fatal error"*|*"] error"*) echo ERROR;;
    *"warning cs"*|*warning*|*"[warn"*) echo WARN;;
    *) echo INFO;;
  esac
}
is_stack() { case "$1" in "  at "*|*"(at "*|"  "*) return 0;; *) return 1;; esac; }

echo "[dcl-log-monitor] log=$LOG tmux=$SESSION digest=${DIGEST}s spool=$SPOOL"
deliver "[dcl-log-monitor] online — watching $(basename "$LOG"); errors pushed immediately, warn/info digest every ${DIGEST}s."

# Reader: tail the log, classify, push errors now / buffer the rest.
( tail -n0 -F "$LOG" 2>/dev/null | while IFS= read -r line; do
    [ -z "$line" ] && continue
    if is_stack "$line"; then printf '%s\n' "$line" >> "$SPOOL/detail.log"; continue; fi  # archive stack noise, never push/digest
    sev=$(classify "$line")
    if [ "$sev" = ERROR ]; then
      [ "$line" = "${LAST_ERR:-}" ] && continue         # dedup identical consecutive errors
      LAST_ERR="$line"
      deliver "[DCL ERROR] $line"
    else
      printf '%s: %s\n' "$sev" "$line" >> "$DBUF"
    fi
  done ) &
TAILPID=$!
trap 'kill "$TAILPID" 2>/dev/null; exit 0' INT TERM

# Flusher: every DIGEST secs, push one digest of the buffered warn/info.
while kill -0 "$TAILPID" 2>/dev/null; do
  sleep "$DIGEST"
  if [ -s "$DBUF" ]; then
    n=$(wc -l < "$DBUF" | tr -d ' ')
    w=$(grep -c '^WARN' "$DBUF" 2>/dev/null || true)
    last=$(tail -n 3 "$DBUF" | tr '\n' '|' | sed 's/|$//')
    deliver "[DCL ${DIGEST}s digest] ${n} msgs (${w:-0} warn) | last: ${last}"
    cat "$DBUF" >> "$SPOOL/digest.archive"; : > "$DBUF"
  fi
done
